{
  "name": "mcintosh-bank",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.5 <21",
    "npm": ">=10 <11"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "commitlint": "commitlint --edit $HUSKY_GIT_PARAMS"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^17",
    "@commitlint/config-conventional": "^17",
    "@storybook/addon-a11y": "^10.3.0",
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/nextjs-vite": "^10.3.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^21.1.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/testing-library__jest-dom": "^5",
    "@vitest/coverage-v8": "^1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9",
    "jsdom": "^22.1.0",
    "prettier": "^3",
    "storybook": "^10.3.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^1.6.1"
  }
